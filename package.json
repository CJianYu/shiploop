{
  "name": "shiploop",
  "version": "0.1.0",
  "description": "A low-friction, agent-agnostic workflow for proving, reviewing, and shipping small changes.",
  "type": "module",
  "bin": {
    "shiploop": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "schemas",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit && eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run check && npm test && npm run build"
  },
  "keywords": [
    "ai-agent",
    "developer-workflow",
    "git",
    "local-ci",
    "atomic-commits"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.15",
    "eslint": "^9.31.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
